{
  "name": "@ranki.io/seo-aeo-mcp",
  "version": "0.1.0",
  "description": "Free SEO audit + AEO audit MCP server for Claude Code, Cursor, Windsurf and ChatGPT Desktop. 22 tools: on-page SEO scorecard, Answer Engine Optimization checks, Google Core Web Vitals via PageSpeed Insights, image optimization (AVIF + WebP + responsive picture markup), sitemap.xml / llms.txt / robots.txt generation, hidden-page classifier, title + meta proposals, keyword gap analysis, topic ideas, plus paid bridge tools to your Google Search Console keywords and AI citations.",
  "type": "module",
  "bin": {
    "ranki-seo-aeo-mcp": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "serve": "node dist/index.js --serve",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "seo",
    "seo-audit",
    "seo-tool",
    "seo-mcp",
    "aeo",
    "aeo-audit",
    "aeo-mcp",
    "answer-engine-optimization",
    "ai-search-optimization",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "core-web-vitals",
    "lighthouse-audit",
    "pagespeed-insights",
    "image-optimization",
    "webp",
    "avif",
    "sitemap-generator",
    "llms-txt",
    "robots-txt",
    "json-ld",
    "faqpage-schema",
    "google-search-console",
    "chatgpt-citations",
    "claude-citations",
    "perplexity-citations",
    "ai-overviews",
    "vibe-coding",
    "claude-code",
    "claude-desktop",
    "cursor",
    "windsurf",
    "chatgpt-desktop",
    "ranki",
    "ranking",
    "ranki-io"
  ],
  "author": "Ranki.io <support@ranki.io> (https://ranki.io)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/1fancy/seo-aeo-audit-mcp-ranki.git",
